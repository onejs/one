      },
      "import": "./dist/esm/split-view/index.mjs",
      "require": "./dist/cjs/split-view/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-screens": "~4.23.0",
    "react-native-safe-area-context": ">=5.4.0"
  },
