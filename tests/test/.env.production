# In production tests, we manually unset `VITE_TEST_ENV_MODE` in Vitest
# so that Vitest environment does not interfere with the bundling process.
# Search for [WR-B3ATY2VK] in the codebase for more info.
VITE_TEST_ENV_MODE=production_value

# native prod tests need to know the server URL for loader requests
ONE_SERVER_URL=http://localhost:3456
