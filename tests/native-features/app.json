{
  "name": "NativeFeatureTests",
  "slug": "native-feature-tests",
  "scheme": "nativefeatures",
  "plugins": [
    "one/expo-plugin",
    [
      "expo-build-properties",
      {
        "ios": {
          "deploymentTarget": "16.0",
          "ccacheEnabled": true
        }
      }
    ]
  ],
  "platforms": ["ios", "android"],
  "android": {
    "package": "dev.vxrn.native.tests"
  },
  "ios": {
    "bundleIdentifier": "dev.vxrn.native.tests"
  }
}
